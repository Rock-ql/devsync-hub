# DevSync Hub 环境配置

# 数据库配置
DB_NAME=devsync
DB_USER=postgres
DB_PASSWORD=postgres
DB_PORT=5432

# Redis 配置
REDIS_PORT=6379
REDIS_PASSWORD=

# 后端配置
BACKEND_PORT=8080
